source "https://rubygems.org"

gem "jekyll"

# 解決 Windows 報錯的救星 (一定要留著！)
gem "tzinfo-data", platforms: [:mingw, :mswin, :x64_mingw, :jruby]
gem "webrick"

# 👇 這裡是截圖裡 _config.yml 要求的三個外掛
gem "jekyll-paginate"  # 分頁功能 (造成剛剛紅字的主因)
gem "jekyll-feed"      # RSS 訂閱功能 (沒裝的話網站底部可能會壞掉)
gem "jekyll-seo-tag"   # SEO 優化 (沒裝的話網頁標題會變亂碼)